bdqs:MeasureShape
    a sh:NodeShape ;
    sh:target [
        a sh:SPARQLTarget ;
        sh:select """
            PREFIX rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
            PREFIX bdqffdq: <https://rs.tdwg.org/bdqffdq/terms/>
