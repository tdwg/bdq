@prefix sh:       <http://www.w3.org/ns/shacl#> .
@prefix rdf:      <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:     <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:      <http://www.w3.org/2001/XMLSchema#> .
@prefix owl:      <http://www.w3.org/2002/07/owl#> .
@prefix dcterms:  <http://purl.org/dc/terms/> .
@prefix bdqffdq:  <https://rs.tdwg.org/bdqffdq/terms/> .
@prefix bdqval:   <https://rs.tdwg.org/bdqval/terms/> .
@prefix bdqs:     <https://rs.tdwg.org/bdqffdq/shacl/> .
@base             <https://rs.tdwg.org/bdqffdq/shacl/> .

########################################################################
# SHACL Shapes for the Biodiversity Data Quality Fitness for Use
# Framework Ontology (bdqffdq:)
#
# Derived from normative guidance in:
#   Section 3 "Use of Ontology Terms (normative)"
#   Section 4 "Fitness For Use Framework — Mathematical Formalization
#               (normative)"
#
# Severity mapping:
#   sh:Violation  ↔  MUST / MUST NOT
#   sh:Warning    ↔  SHOULD / SHOULD NOT
#   sh:Info       ↔  MAY
#
# NOTE on versioned URIs: bdqtest.ttl uses a versioned-URI pattern in
# which every test exists as two typed individuals:
#   bdqtest:{uuid}           (canonical/abstract, minimal properties)
#   bdqtest:{uuid}-{date}    (versioned, carries full property set)
# Both are typed e.g. bdqffdq:Validation.  Shapes that check for the
# presence of required/recommended properties (sections 3-10) therefore
# use sh:SPARQLTarget restricted to individuals that carry
# dcterms:issued, which identifies the versioned form.  Shapes in
# section 20 use their own SPARQL SELECT logic and are unaffected.
########################################################################

bdqs:
    a owl:Ontology ;
    dcterms:issued "2026-03-23" ;
    rdfs:label "SHACL Shapes for the bdqffdq: Fitness For Use Framework Ontology"@en ;
    rdfs:comment """SHACL constraints derived from the normative guidance in
Sections 3 and 4 of the bdqffdq: ontology terms document.
sh:Violation = MUST/MUST NOT  |  sh:Warning = SHOULD/SHOULD NOT  |  sh:Info = MAY"""@en ;
    owl:imports <https://rs.tdwg.org/bdqffdq/terms> .


########################################################################
# 1.  UseCase
########################################################################

bdqs:UseCaseShape
    a sh:NodeShape ;
    sh:target [
        a sh:SPARQLTarget ;
        sh:select """
            PREFIX rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
            PREFIX bdqffdq: <https://rs.tdwg.org/bdqffdq/terms/>
            PREFIX dcterms: <http://purl.org/dc/terms/>
            SELECT ?this WHERE {
                ?this rdf:type  bdqffdq:UseCase ;
                      dcterms:issued ?issued .
            }
        """ ;
    ] ;
    sh:name "Use Case"@en ;
    sh:description "Constraints for bdqffdq:UseCase; see §3.1.2."@en ;

    sh:property [
        sh:path     bdqffdq:hasFitnessRequirements ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:severity sh:Warning ;
        sh:message  "UseCase SHOULD have exactly one bdqffdq:hasFitnessRequirements."@en ;
    ] ;

    sh:property [
        sh:path     rdfs:label ;
        sh:minCount 1 ;
        sh:severity sh:Warning ;
        sh:message  "UseCase SHOULD have at least one rdfs:label."@en ;
    ] .

########################################################################
# 2.  Policy Shapes
########################################################################

bdqs:ValidationPolicyShape
    a sh:NodeShape ;
    sh:targetClass bdqffdq:ValidationPolicy ;
    sh:name "Validation Policy"@en ;
    sh:description "Constraints for bdqffdq:ValidationPolicy; see §3.1.2."@en ;

    sh:property [
        sh:path     bdqffdq:hasUseCase ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:class    bdqffdq:UseCase ;
        sh:severity sh:Warning ;
        sh:message  "ValidationPolicy SHOULD have exactly one bdqffdq:hasUseCase pointing to a UseCase."@en ;
    ] ;

    sh:property [
        sh:path     bdqffdq:includedInPolicy ;
        sh:minCount 1 ;
        sh:class    bdqffdq:Validation ;
        sh:severity sh:Warning ;
        sh:message  "ValidationPolicy SHOULD include at least one Validation via bdqffdq:includedInPolicy."@en ;
    ] .


bdqs:MeasurementPolicyShape
    a sh:NodeShape ;
    sh:targetClass bdqffdq:MeasurementPolicy ;
    sh:name "Measurement Policy"@en ;
    sh:description "Constraints for bdqffdq:MeasurementPolicy; see §3.1.2."@en ;

    sh:property [
        sh:path     bdqffdq:hasUseCase ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:class    bdqffdq:UseCase ;
        sh:severity sh:Warning ;
        sh:message  "MeasurementPolicy SHOULD have exactly one bdqffdq:hasUseCase pointing to a UseCase."@en ;
    ] ;

    sh:property [
        sh:path     bdqffdq:includedInPolicy ;
        sh:minCount 1 ;
        sh:class    bdqffdq:Measure ;
        sh:severity sh:Warning ;
        sh:message  "MeasurementPolicy SHOULD include at least one Measure via bdqffdq:includedInPolicy."@en ;
    ] .


bdqs:AmendmentPolicyShape
    a sh:NodeShape ;
    sh:targetClass bdqffdq:AmendmentPolicy ;
    sh:name "Amendment Policy"@en ;
    sh:description "Constraints for bdqffdq:AmendmentPolicy; see §3.1.2."@en ;

    sh:property [
        sh:path     bdqffdq:hasUseCase ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:class    bdqffdq:UseCase ;
        sh:severity sh:Warning ;
        sh:message  "AmendmentPolicy SHOULD have exactly one bdqffdq:hasUseCase pointing to a UseCase."@en ;
    ] ;

    sh:property [
        sh:path     bdqffdq:includedInPolicy ;
        sh:minCount 1 ;
        sh:class    bdqffdq:Amendment ;
        sh:severity sh:Warning ;
        sh:message  "AmendmentPolicy SHOULD include at least one Amendment via bdqffdq:includedInPolicy."@en ;
    ] .


bdqs:IssuePolicyShape
    a sh:NodeShape ;
    sh:targetClass bdqffdq:IssuePolicy ;
    sh:name "Issue Policy"@en ;
    sh:description "Constraints for bdqffdq:IssuePolicy; see §3.1.2."@en ;

    sh:property [
        sh:path     bdqffdq:hasUseCase ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:class    bdqffdq:UseCase ;
        sh:severity sh:Warning ;
        sh:message  "IssuePolicy SHOULD have exactly one bdqffdq:hasUseCase pointing to a UseCase."@en ;
    ] ;

    sh:property [
        sh:path     bdqffdq:includedInPolicy ;
        sh:minCount 1 ;
        sh:class    bdqffdq:Issue ;
        sh:severity sh:Warning ;
        sh:message  "IssuePolicy SHOULD include at least one Issue via bdqffdq:includedInPolicy."@en ;
    ] .


########################################################################
# 3.  DataQualityNeed — general constraints (apply to all four subtypes)
#
# Uses sh:SPARQLTarget restricted to instances carrying dcterms:issued
# (i.e. versioned instances only) to avoid false positives against the
# canonical/abstract URI companions in bdqtest.ttl.
########################################################################

bdqs:DataQualityNeedShape
    a sh:NodeShape ;
    sh:target [
        a sh:SPARQLTarget ;
        sh:select """
            PREFIX rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
            PREFIX bdqffdq: <https://rs.tdwg.org/bdqffdq/terms/>
            PREFIX dcterms: <http://purl.org/dc/terms/>
            SELECT ?this WHERE {
                {   { ?this rdf:type bdqffdq:Validation  }
                    UNION { ?this rdf:type bdqffdq:Issue     }
                    UNION { ?this rdf:type bdqffdq:Measure   }
                    UNION { ?this rdf:type bdqffdq:Amendment }
                }
                ?this dcterms:issued ?issued .
            }
        """ ;
    ] ;
    sh:name "Data Quality Need"@en ;
    sh:description "General constraints for all bdqffdq:DataQualityNeed subclass instances; see §§3.1.2, 3.3."@en ;

    # MUST have exactly one hasResourceType = SingleRecord | MultiRecord (§3.1.2)
    sh:property [
        sh:path     bdqffdq:hasResourceType ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:in       ( bdqffdq:SingleRecord bdqffdq:MultiRecord ) ;
        sh:severity sh:Violation ;
        sh:message  "DataQualityNeed MUST have exactly one bdqffdq:hasResourceType of bdqffdq:SingleRecord or bdqffdq:MultiRecord."@en ;
    ] ;

    # SHOULD have at least one rdfs:label (§3.1.2)
    sh:property [
        sh:path     rdfs:label ;
        sh:minCount 1 ;
        sh:severity sh:Warning ;
        sh:message  "DataQualityNeed SHOULD have at least one rdfs:label."@en ;
    ] ;

    # SHOULD be the object of at least one bdqffdq:includedInPolicy (§3.1.2)
    sh:property [
        sh:path     [ sh:inversePath bdqffdq:includedInPolicy ] ;
        sh:minCount 1 ;
        sh:severity sh:Warning ;
        sh:message  "DataQualityNeed SHOULD be included in at least one Policy via bdqffdq:includedInPolicy."@en ;
    ] ;

    # SHOULD have exactly one hasActedUponInformationElement → ActedUpon (§3.1.2)
    sh:property [
        sh:path     bdqffdq:hasActedUponInformationElement ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:class    bdqffdq:ActedUpon ;
        sh:severity sh:Warning ;
        sh:message  "DataQualityNeed SHOULD have exactly one bdqffdq:hasActedUponInformationElement pointing to a bdqffdq:ActedUpon."@en ;
    ] ;

    # SHOULD have zero or exactly one hasConsultedInformationElement → Consulted (§3.1.2)
    sh:property [
        sh:path     bdqffdq:hasConsultedInformationElement ;
        sh:maxCount 1 ;
        sh:class    bdqffdq:Consulted ;
        sh:severity sh:Warning ;
        sh:message  "DataQualityNeed SHOULD have zero or exactly one bdqffdq:hasConsultedInformationElement pointing to a bdqffdq:Consulted."@en ;
    ] .


########################################################################
# 4.  Validation
########################################################################

bdqs:ValidationShape
    a sh:NodeShape ;
    sh:target [
        a sh:SPARQLTarget ;
        sh:select """
            PREFIX rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
            PREFIX bdqffdq: <https://rs.tdwg.org/bdqffdq/terms/>
            PREFIX dcterms: <http://purl.org/dc/terms/>
            SELECT ?this WHERE {
                ?this rdf:type  bdqffdq:Validation ;
                      dcterms:issued ?issued .
            }
        """ ;
    ] ;
    sh:name "Validation"@en ;
    sh:description "Constraints specific to bdqffdq:Validation; see §§3.1.2, 3.3."@en ;

    sh:property [
        sh:path     bdqffdq:hasDataQualityDimension ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:class    bdqffdq:DataQualityDimension ;
        sh:severity sh:Warning ;
        sh:message  "Validation SHOULD have exactly one bdqffdq:hasDataQualityDimension."@en ;
    ] ;

    sh:property [
        sh:path     bdqffdq:hasCriterion ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:class    bdqffdq:Criterion ;
        sh:severity sh:Warning ;
        sh:message  "Validation SHOULD have exactly one bdqffdq:hasCriterion."@en ;
    ] ;

    sh:property [
        sh:path     [ sh:inversePath bdqffdq:forValidation ] ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:class    bdqffdq:ValidationMethod ;
        sh:severity sh:Warning ;
        sh:message  "Validation SHOULD be the object of exactly one bdqffdq:forValidation from a bdqffdq:ValidationMethod."@en ;
    ] .


