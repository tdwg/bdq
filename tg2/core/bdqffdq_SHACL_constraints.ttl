    a sh:NodeShape ;
    sh:target [
        a sh:SPARQLTarget ;
        sh:select """
            PREFIX rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
            PREFIX bdqffdq: <https://rs.tdwg.org/bdqffdq/terms/>
            PREFIX dcterms: <http://purl.org/dc/terms/>
            SELECT ?this WHERE {
                ?this rdf:type  bdqffdq:IssueMethod ;
                      dcterms:issued ?issued .
            }
        """ ;
    ] ;
    sh:name "Issue Method"@en ;
    sh:description "Constraints for bdqffdq:IssueMethod; see §§3.1.3, 3.1.4, 3.3."@en ;

    sh:property [
        sh:path     bdqffdq:forIssue ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:class    bdqffdq:Issue ;
        sh:severity sh:Warning ;
        sh:message  "IssueMethod SHOULD have exactly one bdqffdq:forIssue."@en ;
    ] ;

    sh:property [
        sh:path     bdqffdq:hasSpecification ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:class    bdqffdq:Specification ;
        sh:severity sh:Warning ;
        sh:message  "IssueMethod SHOULD have exactly one bdqffdq:hasSpecification."@en ;
    ] .


bdqs:MeasurementMethodShape
    a sh:NodeShape ;
    sh:target [
        a sh:SPARQLTarget ;
        sh:select """
            PREFIX rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
            PREFIX bdqffdq: <https://rs.tdwg.org/bdqffdq/terms/>
            PREFIX dcterms: <http://purl.org/dc/terms/>
            SELECT ?this WHERE {
                ?this rdf:type  bdqffdq:MeasurementMethod ;
                      dcterms:issued ?issued .
            }
        """ ;
    ] ;
    sh:name "Measurement Method"@en ;
    sh:description "Constraints for bdqffdq:MeasurementMethod; see §§3.1.3, 3.1.4, 3.3."@en ;

    sh:property [
        sh:path     bdqffdq:forMeasure ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:class    bdqffdq:Measure ;
        sh:severity sh:Warning ;
        sh:message  "MeasurementMethod SHOULD have exactly one bdqffdq:forMeasure."@en ;
    ] ;

    sh:property [
        sh:path     bdqffdq:hasSpecification ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:class    bdqffdq:Specification ;
        sh:severity sh:Warning ;
        sh:message  "MeasurementMethod SHOULD have exactly one bdqffdq:hasSpecification."@en ;
    ] .


bdqs:AmendmentMethodShape
    a sh:NodeShape ;
    sh:target [
        a sh:SPARQLTarget ;
        sh:select """
            PREFIX rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
            PREFIX bdqffdq: <https://rs.tdwg.org/bdqffdq/terms/>
            PREFIX dcterms: <http://purl.org/dc/terms/>
            SELECT ?this WHERE {
                ?this rdf:type  bdqffdq:AmendmentMethod ;
                      dcterms:issued ?issued .
            }
        """ ;
    ] ;
    sh:name "Amendment Method"@en ;
    sh:description "Constraints for bdqffdq:AmendmentMethod; see §§3.1.3, 3.1.4, 3.3."@en ;

    sh:property [
        sh:path     bdqffdq:forAmendment ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:class    bdqffdq:Amendment ;
        sh:severity sh:Warning ;
        sh:message  "AmendmentMethod SHOULD have exactly one bdqffdq:forAmendment."@en ;
    ] ;

    sh:property [
        sh:path     bdqffdq:hasSpecification ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:class    bdqffdq:Specification ;
        sh:severity sh:Warning ;
        sh:message  "AmendmentMethod SHOULD have exactly one bdqffdq:hasSpecification."@en ;
