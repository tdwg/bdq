        sh:message  "Amendment SHOULD be the object of exactly one bdqffdq:forAmendment from a bdqffdq:AmendmentMethod."@en ;
    ] .


########################################################################
# 8.  InformationElement Shapes
########################################################################

bdqs:ActedUponShape
    a sh:NodeShape ;
    sh:targetClass bdqffdq:ActedUpon ;
    sh:name "Acted Upon"@en ;
    sh:description "Constraints for bdqffdq:ActedUpon; see §3.1.2."@en ;

    sh:property [
        sh:path     bdqffdq:composedOf ;
        sh:minCount 1 ;
        sh:severity sh:Warning ;
        sh:message  "ActedUpon SHOULD have at least one bdqffdq:composedOf property."@en ;
    ] .


bdqs:ConsultedShape
    a sh:NodeShape ;
    sh:targetClass bdqffdq:Consulted ;
    sh:name "Consulted"@en ;
    sh:description "Constraints for bdqffdq:Consulted; see §3.1.2."@en ;

    sh:property [
        sh:path     bdqffdq:composedOf ;
        sh:minCount 1 ;
        sh:severity sh:Warning ;
        sh:message  "Consulted SHOULD have at least one bdqffdq:composedOf property."@en ;
    ] .


bdqs:AbstractInformationElementShape
    a sh:NodeShape ;
    sh:targetClass bdqffdq:AbstractInformationElement ;
    sh:name "Abstract Information Element"@en ;
    sh:description "Constraints for bdqffdq:AbstractInformationElement; see §3.1.2."@en ;

    sh:property [
        sh:path     rdfs:label ;
        sh:minCount 1 ;
        sh:severity sh:Warning ;
        sh:message  "AbstractInformationElement SHOULD have at least one rdfs:label."@en ;
    ] ;

    sh:property [
        sh:path     rdfs:comment ;
        sh:minCount 1 ;
        sh:severity sh:Warning ;
        sh:message  "AbstractInformationElement SHOULD have at least one rdfs:comment."@en ;
    ] .


########################################################################
# 9.  DataQualityMethod Shapes
########################################################################

bdqs:ValidationMethodShape
    a sh:NodeShape ;
    sh:target [
        a sh:SPARQLTarget ;
        sh:select """
            PREFIX rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
            PREFIX bdqffdq: <https://rs.tdwg.org/bdqffdq/terms/>
            PREFIX dcterms: <http://purl.org/dc/terms/>
            SELECT ?this WHERE {
                ?this rdf:type  bdqffdq:ValidationMethod ;
                      dcterms:issued ?issued .
            }
        """ ;
    ] ;
    sh:name "Validation Method"@en ;
    sh:description "Constraints for bdqffdq:ValidationMethod; see §§3.1.3, 3.1.4, 3.3."@en ;

    sh:property [
        sh:path     bdqffdq:forValidation ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:class    bdqffdq:Validation ;
        sh:severity sh:Warning ;
        sh:message  "ValidationMethod SHOULD have exactly one bdqffdq:forValidation."@en ;
    ] ;

    sh:property [
        sh:path     bdqffdq:hasSpecification ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:class    bdqffdq:Specification ;
        sh:severity sh:Warning ;
        sh:message  "ValidationMethod SHOULD have exactly one bdqffdq:hasSpecification."@en ;
    ] .


