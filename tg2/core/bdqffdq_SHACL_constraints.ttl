        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:class    bdqffdq:DataQualityDimension ;
        sh:severity sh:Warning ;
        sh:message  "Amendment SHOULD have exactly one bdqffdq:hasDataQualityDimension."@en ;
    ] ;

    sh:property [
        sh:path     bdqffdq:hasEnhancement ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
