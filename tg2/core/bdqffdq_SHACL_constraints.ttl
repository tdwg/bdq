        sh:class    bdqffdq:IssueMethod ;
        sh:severity sh:Warning ;
        sh:message  "Issue SHOULD be the object of exactly one bdqffdq:forIssue from a bdqffdq:IssueMethod."@en ;
    ] .


########################################################################
